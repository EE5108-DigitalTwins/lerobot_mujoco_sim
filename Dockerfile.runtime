FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Runtime image for capture + inference (no local training stack).
# Notes:
# - CPU-only runtime (non-CUDA base image + PyTorch CPU wheels).
# - Avoids heavy dev tooling (Jupyter, etc.). Some minimal build deps are
#   installed temporarily to build `evdev` when installing `lerobot`.

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    git-lfs \
    build-essential \
    python3-venv \
    ffmpeg \
    unzip \
    libgl1 \
    libgl1-mesa-dri \
    libglib2.0-0 \
    libglfw3 \
    libglew2.2 \
    libosmesa6 \
    libegl1 \
    libx11-6 \
    libxext6 \
    libxrender1 \
    libxrandr2 \
    libxinerama1 \
    libxi6 \
    libxcursor1 \
    libxkbcommon0 \
    libsm6 \
    libxmu6 \
    && rm -rf /var/lib/apt/lists/*

# Ubuntu 24.04 ships Python 3.12 natively.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.12 1

# Hugging Face CLI (for `huggingface-cli login`, uploads, etc.)
RUN curl -LsSf https://hf.co/cli/install.sh | bash
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /workspace

ENV VIRTUAL_ENV=/opt/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

RUN python -m venv "$VIRTUAL_ENV" && \
    "$VIRTUAL_ENV/bin/python" -m pip install --upgrade pip setuptools wheel

# PyTorch CPU (inference)
RUN python -m pip install --no-cache-dir \
    torch==2.6.0 \
    torchvision==0.21.0 \
    --index-url https://download.pytorch.org/whl/cpu

# Core runtime deps for MuJoCo + LeRobot dataset IO + inference
RUN python -m pip install --no-cache-dir \
    mujoco==3.1.6 \
    numpy \
    Pillow \
    opencv-python \
    glfw \
    termcolor \
    pyarrow \
    PyYAML \
    mink \
    safetensors==0.5.3 \
    datasets==3.4.1 \
    transformers==4.50.3

# LeRobot from main (matches Dockerfile for consistency)
RUN python -m pip install --no-cache-dir \
  # Pin to a commit compatible with this repo's `lerobot.common.*` imports.
  --ignore-installed \
  "git+https://github.com/huggingface/lerobot.git@10b7b3532543b4adfb65760f02a49b4c537afde7#egg=lerobot"

# Remove build dependencies to keep runtime image smaller.
RUN apt-get update && apt-get purge -y --auto-remove \
    build-essential \
    python3.12-dev \
    && rm -rf /var/lib/apt/lists/*

COPY . /workspace

RUN if [ -f /workspace/asset/objaverse/plate_11.zip ]; then \
    unzip -o /workspace/asset/objaverse/plate_11.zip -d /workspace/asset/objaverse/; \
    fi

ENV MUJOCO_GL=osmesa

CMD ["bash"]

