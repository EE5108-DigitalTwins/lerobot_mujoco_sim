<mujoco model="Scanned Objects SO101">
    <size memory="500M"/>

    <!-- Simple, proven settings from original tutorial -->
    <option integrator="RK4" noslip_iterations="40" />

    <default>
        <joint armature="0.1" damping="0.1" />
        <default class="visual_only">
            <geom type="mesh" contype="0" conaffinity="0" group="2" />
        </default>
        <default class="no_visual_collision">
            <geom type="capsule" solimp=".9 .99 .001" solref=".015 1" group="3" />
        </default>
        <default class="visual_collision">
            <geom type="mesh" solimp=".9 .99 .001" solref=".015 1" group="2" />
        </default>
    </default>

    <include file="./tabletop/object/floor_isaac_style.xml" />
    <include file="./tabletop/object/object_table.xml" />
    <include file="./tabletop/object/obj_blocks.xml"/>
    <include file="./tabletop/object/obj_bin.xml"/>

    <include file="./so_arm100/SO101/so101_new_calib.xml" />

    <!-- Mocap IK target: in the viewer, double-click the red sphere then drag
         to move the arm.  Non-colliding; position is reset to the TCP on env reset.
         Only active when action_type='eef_pose'. -->
    <worldbody>
        <body name="target" mocap="true" pos="0.35 -0.1 0.95">
            <geom type="sphere" size="0.025" rgba="1 0.2 0.2 0.7"
                  contype="0" conaffinity="0"/>
        </body>
    </worldbody>
</mujoco>
