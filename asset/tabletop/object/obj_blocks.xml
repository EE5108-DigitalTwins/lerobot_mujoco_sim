<mujoco model="obj_blocks">

    <worldbody>
        <!-- Blocks: 2.5cm cubed (25mm x 25mm x 25mm).
             condim=4: torsional friction prevents spinning-in-place; no rolling resistance
               (condim=6 rolling contacts can cause micro-stabilisation at edge contacts).
             solref=0.004: 4ms time constant = stiff wood-like contact, no springback.
             solimp 0.95->0.99: near-rigid, minimal compressibility.
             friction=0.8: realistic sliding friction for wood/plastic (~0.4-0.8).
             Gripper surfaces are given high friction separately in so101_new_calib.xml. -->
        <body name="body_obj_block_1" pos="0.42 -0.16 0.90" euler="0 0 0">
